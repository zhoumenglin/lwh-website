---
interface Skill {
  label: string;
  level: number; // 1-5
  logo?: string;
}

interface Category {
  title: string;
  icon: string;
  skills: Skill[];
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<div class="skill-board">
  {categories.map((cat, ci) => {
    const accents = [
      { bar: 'oklch(0.72 0.10 180), oklch(0.62 0.13 190)', border: 'oklch(0.82 0.05 180 / 0.5)' },
      { bar: 'oklch(0.60 0.10 260), oklch(0.52 0.12 270)', border: 'oklch(0.82 0.04 260 / 0.4)' },
      { bar: 'oklch(0.65 0.12 50), oklch(0.58 0.14 40)', border: 'oklch(0.85 0.05 50 / 0.4)' },
      { bar: 'oklch(0.62 0.10 30), oklch(0.55 0.12 20)', border: 'oklch(0.85 0.04 30 / 0.4)' },
    ];
    const accent = accents[ci % accents.length];
    return (
    <div class="skill-card" style={`animation-delay: ${ci * 0.1}s; --bar-gradient: linear-gradient(90deg, ${accent.bar}); --header-border: ${accent.border};`}>
      <div class="skill-card__header">
        <span class="skill-card__icon">{cat.icon}</span>
        <h3 class="skill-card__title">{cat.title}</h3>
      </div>
      <div class="skill-card__list">
        {cat.skills.map((skill) => (
          <div class="skill-item">
            <div class="skill-item__info">
              {skill.logo && <img src={skill.logo} alt="" class="skill-item__logo" />}
              <span class="skill-item__label">{skill.label}</span>
            </div>
            <div class="skill-item__bar-bg">
              <div
                class="skill-item__bar-fill"
                style={`width: ${skill.level * 20}%`}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
    );
  })}
</div>

<style>
  .skill-board {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .skill-board {
      grid-template-columns: 1fr;
    }
  }

  .skill-card {
    background: linear-gradient(160deg, oklch(0.98 0.01 190 / 0.8), oklch(0.96 0.015 195 / 0.5));
    border: 1px solid oklch(0.92 0.02 190 / 0.4);
    border-radius: 1rem;
    padding: 1.5rem;
    animation: cardSlideUp 0.5s cubic-bezier(0.25, 0.1, 0.25, 1) both;
    transition: box-shadow 0.3s ease, transform 0.2s ease;
  }

  .skill-card:hover {
    box-shadow: 0 8px 28px oklch(0.75 0.06 190 / 0.15);
    transform: translateY(-2px);
  }

  @keyframes cardSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .skill-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--header-border, oklch(0.92 0.02 190 / 0.4));
  }

  .skill-card__icon {
    font-size: 1.25rem;
  }

  .skill-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: oklch(0.35 0.06 185);
    letter-spacing: 0.03em;
  }

  .skill-card__list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .skill-item__info {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    width: 6.5rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  .skill-item__logo {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .skill-item__label {
    font-size: 0.72rem;
    color: oklch(0.40 0.03 190);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .skill-item__bar-bg {
    flex: 1;
    min-width: 3rem;
    height: 6px;
    background: oklch(0.94 0.015 195 / 0.6);
    border-radius: 3px;
    overflow: hidden;
  }

  .skill-item__bar-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--bar-gradient, linear-gradient(90deg, oklch(0.72 0.10 180), oklch(0.62 0.13 190)));
    transition: width 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
</style>
