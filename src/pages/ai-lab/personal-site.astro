---
import BaseLayout from "../../layouts/BaseLayout.astro";

// All works in order — update this list when adding new works
const allWorks = [
  { id: "personal-site", title: "AI 协作建站：从 0 到 1 的个人品牌站" },
  // { id: "growth-dashboard", title: "AI 增长实验看板" },
  // { id: "prompt-templates", title: "Prompt 工作流模板库" },
];

const currentIndex = allWorks.findIndex(w => w.id === "personal-site");
const prevWork = currentIndex > 0 ? allWorks[currentIndex - 1] : null;
const nextWork = currentIndex < allWorks.length - 1 ? allWorks[currentIndex + 1] : null;

const steps = [
  {
    phase: "01",
    title: "需求定义",
    desc: "明确目标：面向 AI 产品岗面试官，展示增长/商业化/出海的实战经验与 AI 产品认知",
    detail: "与 Claude 对话明确站点定位、目标受众、核心模块，确定 Astro + Tailwind 技术栈",
    tag: "产品思维",
  },
  {
    phase: "02",
    title: "信息架构",
    desc: "6 大模块设计：首页 → 项目经历 → AI 洞察 → 技能 → 简历 → 联系方式",
    detail: "用产品经理的思维规划内容层级，确保面试官能在 30 秒内建立认知",
    tag: "架构设计",
  },
  {
    phase: "03",
    title: "视觉系统",
    desc: "薄荷绿主题色 + 莫兰迪色系搭配，从紫色系迭代到清爽大方的最终方案",
    detail: "参考业界优秀个人站，通过多轮 AI 协作调整配色、间距、动效，建立统一视觉语言",
    tag: "设计迭代",
  },
  {
    phase: "04",
    title: "交互细节",
    desc: "滚动翻页、侧边栏联动、文章目录导航、头像入场动效",
    detail: "每个交互都经历了「提出 → 实现 → 体验 → 反馈 → 优化」的闭环",
    tag: "体验打磨",
  },
  {
    phase: "05",
    title: "内容创作",
    desc: "5 篇深度 AI 洞察文章，覆盖商业化、增长、出海、工作流、转型",
    detail: "结合 7 年一线经验，用 AI 辅助结构化输出，确保专业深度与可读性",
    tag: "内容策略",
  },
  {
    phase: "06",
    title: "持续迭代",
    desc: "从首版上线到当前版本，经历 50+ 轮优化，每轮都基于真实使用反馈",
    detail: "AI 实验室模块本身就是迭代的产物——证明 AI 协作能力的最好方式是展示过程",
    tag: "敏捷迭代",
  },
];

const highlights = [
  { num: "50+", label: "轮 AI 协作迭代" },
  { num: "6", label: "大功能模块" },
  { num: "5", label: "篇深度文章" },
  { num: "100%", label: "AI 协作交付" },
];
---

<BaseLayout sideBarActiveItemID="ai-lab" enablePageScroll={false}>
  <div class="pb-12 mt-5 case-page">
    <!-- Header -->
    <div class="case-header">
      <span class="case-badge">案例复盘</span>
      <h1 class="case-title">AI 协作建站：从 0 到 1 的个人品牌站</h1>
      <p class="case-subtitle">
        零代码基础，全程通过与 Claude 对话完成需求定义、视觉设计、前端开发、内容创作。<br/>
        这个站点本身就是我 AI 产品能力的最佳证明。
      </p>
    </div>

    <!-- Key numbers -->
    <div class="case-highlights">
      {highlights.map((h) => (
        <div class="case-highlight">
          <span class="case-highlight__num">{h.num}</span>
          <span class="case-highlight__label">{h.label}</span>
        </div>
      ))}
    </div>

    <!-- Core insight -->
    <div class="case-insight">
      <span class="case-insight__icon">💡</span>
      <div>
        <p class="case-insight__title">核心洞察</p>
        <p class="case-insight__text">
          AI 不是替代产品经理，而是把产品经理的能力半径扩大了 10 倍。AI帮我把「知道」变成了「做到」。
        </p>
      </div>
    </div>

    <!-- Build process -->
    <div class="case-section">
      <h2 class="case-section__title">构建过程</h2>
      <div class="case-steps">
        {steps.map((step) => (
          <div class="case-step">
            <div class="case-step__left">
              <span class="case-step__phase">{step.phase}</span>
              <span class="case-step__tag">{step.tag}</span>
            </div>
            <div class="case-step__body">
              <h3 class="case-step__title">{step.title}</h3>
              <p class="case-step__desc">{step.desc}</p>
              <p class="case-step__detail">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech stack -->
    <div class="case-section">
      <h2 class="case-section__title">技术栈</h2>
      <div class="case-stack">
        <div class="case-stack-item">
          <span class="case-stack-item__name">Claude Opus</span>
          <span class="case-stack-item__role">AI 协作伙伴 · 设计 + 开发 + 内容</span>
        </div>
        <div class="case-stack-item">
          <span class="case-stack-item__name">Astro</span>
          <span class="case-stack-item__role">静态站点框架 · 页面路由 + 内容管理</span>
        </div>
        <div class="case-stack-item">
          <span class="case-stack-item__name">Tailwind CSS + DaisyUI</span>
          <span class="case-stack-item__role">样式系统 · 主题 + 组件</span>
        </div>
        <div class="case-stack-item">
          <span class="case-stack-item__name">Vercel</span>
          <span class="case-stack-item__role">部署平台 · 自动构建 + CDN</span>
        </div>
      </div>
    </div>

    <!-- Technical decisions (moved before collaboration) -->
    <div class="case-section">
      <h2 class="case-section__title">技术决策：为什么这么选</h2>
      <p class="case-section__intro">
        在第一步就做了产品架构层面的决策，而不是直接让 AI "帮我写个网页"。每个选择都有明确理由。
      </p>
      <div class="case-decisions">
        <div class="case-decision">
          <div class="case-decision__what">
            <span class="case-decision__choice">Astro 框架</span>
            <span class="case-decision__not">而非裸写 HTML</span>
          </div>
          <p class="case-decision__why">组件化开发，改一处不用改十处。内置内容管理，Markdown 写博客自动生成页面。后续加模块只需加文件，不用重构。</p>
        </div>
        <div class="case-decision">
          <div class="case-decision__what">
            <span class="case-decision__choice">Tailwind + DaisyUI</span>
            <span class="case-decision__not">而非手写 CSS</span>
          </div>
          <p class="case-decision__why">主题系统保证全局一致性。改一个配色变量，全站按钮、标签、背景联动更新。后来从紫色换成薄荷绿，就是靠这个。</p>
        </div>
        <div class="case-decision">
          <div class="case-decision__what">
            <span class="case-decision__choice">GitHub 版本管理</span>
            <span class="case-decision__not">而非本地文件夹</span>
          </div>
          <p class="case-decision__why">每次改动有记录，改坏了能回退。同时也是作品展示——面试官可以看到完整的构建历史。</p>
        </div>
        <div class="case-decision">
          <div class="case-decision__what">
            <span class="case-decision__choice">Vercel 自动部署</span>
            <span class="case-decision__not">而非手动传 FTP</span>
          </div>
          <p class="case-decision__why">push 代码即自动上线，不用折腾服务器。全球 CDN 加速，国内外访问都快。</p>
        </div>

    <!-- Collaboration methodology -->
    <div class="case-section">
      <h2 class="case-section__title">协作方法论：指令式 vs 协作式</h2>
      <p class="case-section__intro">
        大多数人用 AI 建站时，会把每一个像素、颜色、边框都写进 prompt——本质上是把 AI 当代码翻译器。
        我的方式完全不同：<strong>给问题和感受，不给解法</strong>，让 AI 发挥设计能力，我负责判断和取舍。
      </p>

      <div class="case-compare">
        <div class="case-compare__col case-compare__col--old">
          <div class="case-compare__header">
            <span class="case-compare__icon">📋</span>
            <span class="case-compare__label">指令式</span>
          </div>
          <ul class="case-compare__list">
            <li>一次性写长 prompt，指定所有细节</li>
            <li>人做 100% 设计决策，AI 只写代码</li>
            <li>AI 角色 = 代码翻译器</li>
            <li>改 prompt 重来，迭代成本高</li>
            <li>产出像模板，千篇一律</li>
          </ul>
        </div>
        <div class="case-compare__col case-compare__col--new">
          <div class="case-compare__header">
            <span class="case-compare__icon">🤝</span>
            <span class="case-compare__label">协作式（我的方式）</span>
          </div>
          <ul class="case-compare__list">
            <li>多轮短对话，渐进式推进</li>
            <li>人定方向，AI 出方案，人选择</li>
            <li>AI 角色 = 设计搭档</li>
            <li>基于体感持续调优，每轮成本低</li>
            <li>有个人审美和判断力的痕迹</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Chat-style collaboration scenes -->
    <div class="case-section">
      <h2 class="case-section__title">真实协作场景</h2>

      <div class="chat-scene">
        <p class="chat-scene__label">场景一 · 5 轮迭代打磨一个交互细节</p>
        <div class="chat-window">
          <div class="chat-bubble chat-bubble--user">首页看完上滑无法移动到下一 part，必须点侧边栏才行</div>
          <div class="chat-bubble chat-bubble--ai">实现滚动翻页 + 停留检测 + 侧边栏联动</div>
          <div class="chat-bubble chat-bubble--user">文章还没看完就跳走了，太灵敏</div>
          <div class="chat-bubble chat-bubble--ai">增加 800ms 停留 + 累积阈值，文章页禁用翻页</div>
          <div class="chat-bubble chat-bubble--user">还是滑不了，滚动容器检测有问题</div>
          <div class="chat-bubble chat-bubble--ai">换 IntersectionObserver 方案，不依赖 scrollTop</div>
          <div class="chat-bubble chat-bubble--user">出现「继续浏览」后用户再主动往下滚才跳，别自动</div>
          <div class="chat-bubble chat-bubble--ai">提示出现后监听 wheel，用户主动触发</div>
          <div class="chat-bubble chat-bubble--user">太灵敏，要给用户看完内容的空间</div>
          <div class="chat-bubble chat-bubble--ai">按页面长度自适应：长页面滚 30% 触发，短页面滚 60%，确保内容看完</div>
        </div>
        <div class="chat-insight">一个「滚动翻页」交互经历了 5 轮方案迭代。我不写代码，但我能从使用体感精准定位问题，每轮反馈都在推动方案逼近最优解。</div>
      </div>

      <div class="chat-scene">
        <p class="chat-scene__label">场景二 · 否定 AI 方案 → 引导更优方向</p>
        <div class="chat-window">
          <div class="chat-bubble chat-bubble--user">技能模块想做圆形泡泡词云，大的代表技能强</div>
          <div class="chat-bubble chat-bubble--ai">实现了气泡词云组件，螺旋布局自动排列</div>
          <div class="chat-bubble chat-bubble--user">写的太惨了，根本无法查看。你 brainstorm 一下，可以不按我的来，但要契合网站风格</div>
          <div class="chat-bubble chat-bubble--ai">放弃气泡方案，改为分类卡片 + 进度条，按能力维度分组展示</div>
        </div>
        <div class="chat-insight">我的初始想法是错的，但我没执着。关键在于能判断「结果不好」并放手让 AI 重新设计，而不是调参数挽救错误方向。</div>
      </div>

      <div class="chat-scene">
        <p class="chat-scene__label">场景三 · 信息架构问题 → 组合方案</p>
        <div class="chat-window">
          <div class="chat-bubble chat-bubble--user">首页 AI 洞察和侧边栏的洞察内容重复了，怎么加区分度？</div>
          <div class="chat-bubble chat-bubble--ai">首页改精简列表，博客页保留完整卡片。首页是「目录预览」，博客页是「深度浏览」</div>
          <div class="chat-bubble chat-bubble--user">面试官看完一篇文章后应该有导航。侧边栏加目录还是内嵌导航？你看什么方案好？</div>
          <div class="chat-bubble chat-bubble--ai">建议组合方案：文章内 TOC + 底部前后篇导航 + 侧边栏不动。参考 Stripe Docs</div>
        </div>
        <div class="chat-insight">我发现信息架构问题，提出两个备选并征求 AI 意见。最终采纳 AI 的第三种方案——真正的协作，不是单向指挥。</div>
      </div>
    </div>
      </div>
    </div>

    <!-- Retrospective -->
    <div class="case-section">
      <h2 class="case-section__title">协作中的几个关键判断</h2>
      <div class="dev-review">
        <div class="dev-review__content">
          <div class="dev-review__item">
            <h4>体感判断比 Prompt 更重要</h4>
            <p>"hover 过渡不自然"、"信息层级不清楚"——这些问题我说不出技术原因，但能感觉到哪里不对。AI 能执行修复，但发现问题本身靠的是产品直觉，这写不进任何 Prompt 模板。</p>
          </div>
          <div class="dev-review__item">
            <h4>错了就放手，不调参数挽救</h4>
            <p>气泡图方案做出来效果很差，我的第一反应是让 AI 调参数。但试了两轮发现方向本身就不对，果断放弃让 AI 重新提方案。事后看，这个决定省了至少两小时。</p>
          </div>
          <div class="dev-review__item">
            <h4>关注用户路径，不是视觉细节</h4>
            <p>整个过程中我提出的大部分问题不是"按钮颜色不好看"，而是"首页和博客页内容重复了"、"文章没有前后导航"、"需要预留作品集模块"——这些是在为面试官的浏览路径做设计。</p>
          </div>
          <div class="dev-review__item">
            <h4>技术架构决策前置</h4>
            <p>第一步就定了用 Astro 框架而非裸写 HTML、用 Tailwind 设计系统而非手调颜色、用 Vercel 自动部署而非手动 FTP。这些决策让后续迭代成本极低——改全站配色只花了 5 分钟。</p>
          </div>
        </div>
      </div>
    </div>

    <!-- What I learned -->
    <div class="case-section">
      <h2 class="case-section__title">我的收获</h2>
      <div class="case-learnings">
        <div class="case-learning">
          <h4>AI 协作的核心是「提出好问题」</h4>
          <p>模糊的需求得到模糊的结果。我学会了把产品需求拆解成 AI 可执行的具体指令。</p>
        </div>
        <div class="case-learning">
          <h4>迭代比一步到位更重要</h4>
          <p>50+ 轮对话不是效率低，而是每一轮都在逼近更好的体验。这和做产品的逻辑一样。</p>
        </div>
        <div class="case-learning">
          <h4>PM 的审美和判断力是不可替代的</h4>
          <p>AI 生成代码，但「这个间距太大」「颜色不搭」「交互不自然」——这些判断只有人能做。</p>
        </div>
      </div>
    </div>

    <!-- Prev / Next work -->
    {(prevWork || nextWork) && (
      <nav class="case-nav">
        {prevWork ? (
          <a href={`/ai-lab/${prevWork.id}`} class="case-nav__item case-nav__item--prev">
            <span class="case-nav__label">← 上一个作品</span>
            <span class="case-nav__title">{prevWork.title}</span>
          </a>
        ) : <div />}
        {nextWork ? (
          <a href={`/ai-lab/${nextWork.id}`} class="case-nav__item case-nav__item--next">
            <span class="case-nav__label">下一个作品 →</span>
            <span class="case-nav__title">{nextWork.title}</span>
          </a>
        ) : <div />}
      </nav>
    )}

    <!-- Back to lab -->
    <div class="case-back-bottom">
      <a href="/ai-lab" class="case-back">← 返回 AI 实验室</a>
    </div>
  </div>
</BaseLayout>

<style>
  .case-page {
    max-width: 48rem;
  }

  .case-back {
    font-size: 0.78rem;
    color: oklch(0.55 0.05 190);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .case-back:hover {
    color: oklch(0.42 0.10 180);
  }

  /* Header */
  .case-header {
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  .case-badge {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    background: oklch(0.65 0.10 180);
    color: #fff;
    letter-spacing: 0.05em;
  }

  .case-title {
    font-size: 2rem;
    font-weight: 700;
    color: oklch(0.22 0.03 200);
    margin-top: 0.85rem;
    line-height: 1.3;
  }

  .case-subtitle {
    font-size: 0.92rem;
    color: oklch(0.45 0.02 200);
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  /* Highlights — amber accent */
  .case-highlights {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .case-highlight {
    text-align: center;
    padding: 1rem 0.5rem;
    background: oklch(0.97 0.015 75 / 0.35);
    border: 1px solid oklch(0.92 0.03 70 / 0.3);
    border-radius: 0.75rem;
  }

  .case-highlight__num {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: oklch(0.58 0.14 55);
  }

  .case-highlight__label {
    font-size: 0.68rem;
    color: oklch(0.50 0.03 200);
    margin-top: 0.15rem;
    display: block;
  }

  /* Insight callout — indigo accent */
  .case-insight {
    display: flex;
    gap: 0.85rem;
    padding: 1.15rem 1.25rem;
    background: linear-gradient(135deg, oklch(0.96 0.015 260 / 0.3), oklch(0.97 0.01 250 / 0.2));
    border-left: 3px solid oklch(0.58 0.12 260);
    border-radius: 0 0.75rem 0.75rem 0;
    margin-bottom: 2.5rem;
  }

  .case-insight__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .case-insight__title {
    font-size: 0.72rem;
    font-weight: 600;
    color: oklch(0.48 0.10 260);
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .case-insight__text {
    font-size: 0.85rem;
    color: oklch(0.38 0.03 200);
    line-height: 1.7;
  }

  /* Sections */
  .case-section {
    margin-bottom: 3rem;
  }

  .case-section__title {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: oklch(0.30 0.03 200);
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid oklch(0.92 0.03 190 / 0.5);
  }

  /* Steps */
  .case-steps {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .case-step {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-left: 2px solid oklch(0.88 0.04 185);
    transition: border-color 0.3s ease, background 0.3s ease;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  .case-step:hover {
    border-left-color: oklch(0.62 0.10 180);
    background: oklch(0.98 0.008 195 / 0.4);
  }

  .case-step__left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    width: 3.5rem;
  }

  .case-step__phase {
    font-size: 1.1rem;
    font-weight: 700;
    color: oklch(0.58 0.10 180);
  }

  .case-step__tag {
