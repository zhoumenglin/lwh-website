---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout sideBarActiveItemID="contact">
  <div class="pb-12 mt-5">
    <div class="text-3xl font-bold mb-1">联系方式</div>
    <p class="text-base-content/40 text-sm mb-10">欢迎通过以下方式与我联系</p>

    <div class="contact-grid">

      <a href="mailto:lwh1517880@163.com" class="contact-item">
        <div class="contact-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </div>
        <div class="contact-item__body">
          <span class="contact-item__label">邮箱</span>
          <span class="contact-item__value">lwh1517880@163.com</span>
        </div>
        <span class="contact-item__arrow">→</span>
      </a>

      <a href="tel:15735641004" class="contact-item">
        <div class="contact-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="contact-item__body">
          <span class="contact-item__label">电话</span>
          <span class="contact-item__value">157-3564-1004</span>
        </div>
        <span class="contact-item__arrow">→</span>
      </a>

      <a href="https://www.xiaohongshu.com/user/profile/5c24a23e00000000050005df" target="_blank" rel="noopener noreferrer" class="contact-item">
        <div class="contact-item__icon contact-item__icon--xhs">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <div class="contact-item__body">
          <span class="contact-item__label">小红书</span>
          <span class="contact-item__value">查看我的小红书主页</span>
        </div>
        <span class="contact-item__arrow">→</span>
      </a>

      <a href="https://github.com/belalee-ai" target="_blank" rel="noopener noreferrer" class="contact-item">
        <div class="contact-item__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
        <div class="contact-item__body">
          <span class="contact-item__label">GitHub</span>
          <span class="contact-item__value">查看我的 GitHub</span>
        </div>
        <span class="contact-item__arrow">→</span>
      </a>

    </div>
  </div>
</BaseLayout>

<style>
  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 28rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border-radius: 0.85rem;
    border: 1px solid oklch(0.93 0.015 195 / 0.5);
    background: transparent;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
    cursor: pointer;
  }

  .contact-item:hover {
    background: oklch(0.97 0.012 190 / 0.6);
    border-color: oklch(0.85 0.04 185 / 0.5);
    box-shadow: 0 4px 18px oklch(0.80 0.05 190 / 0.12);
    transform: translateX(4px);
  }

  .contact-item__icon {
    width: 2.4rem;
    height: 2.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.6rem;
    background: oklch(0.95 0.02 190 / 0.5);
    color: oklch(0.55 0.08 180);
    flex-shrink: 0;
    transition: all 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .contact-item:hover .contact-item__icon {
    background: oklch(0.68 0.10 180);
    color: #fff;
  }

  .contact-item__icon--xhs {
    color: oklch(0.55 0.08 180);
  }

  .contact-item:hover .contact-item__icon--xhs {
    background: oklch(0.68 0.10 180);
    color: #fff;
  }

  .contact-item__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .contact-item__label {
    font-size: 0.65rem;
    color: oklch(0.60 0.03 195);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .contact-item__value {
    font-size: 0.85rem;
    color: oklch(0.35 0.03 200);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact-item__arrow {
    font-size: 0.85rem;
    color: oklch(0.70 0.05 190);
    opacity: 0;
    transform: translateX(-6px);
    transition: all 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
    flex-shrink: 0;
  }

  .contact-item:hover .contact-item__arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
