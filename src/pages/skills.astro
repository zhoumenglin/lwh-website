---
import BaseLayout from "../layouts/BaseLayout.astro";
import SkillBoard from "../components/SkillBoard.astro";

const categories = [
  {
    title: "核心能力",
    icon: "🎯",
    skills: [
      { label: "C端增长", level: 5 },
      { label: "效果广告投放", level: 5 },
      { label: "订阅商业化", level: 5 },
      { label: "出海增长", level: 4 },
      { label: "数据分析", level: 4 },
      { label: "A/B Testing", level: 4 },
      { label: "用户分层", level: 4 },
    ],
  },
  {
    title: "AI 工具 & 能力",
    icon: "🤖",
    skills: [
      { label: "ChatGPT", level: 5, logo: "/logos/chatgpt.svg" },
      { label: "Claude", level: 5, logo: "/logos/claude.svg" },
      { label: "Prompt Eng.", level: 4 },
      { label: "豆包", level: 4, logo: "/logos/doubao.svg" },
      { label: "Kimi", level: 4, logo: "/logos/kimi.svg" },
    ],
  },
  {
    title: "增长专项",
    icon: "📈",
    skills: [
      { label: "ROAS 优化", level: 4 },
      { label: "eCPM 竞价", level: 4 },
      { label: "SQL", level: 3 },
    ],
  },
  {
    title: "设计 & 协作",
    icon: "🛠",
    skills: [
      { label: "Figma", level: 4, logo: "/logos/figma.svg" },
      { label: "Axure", level: 4, logo: "/logos/axure.svg" },
      { label: "Xmind", level: 4, logo: "/logos/xmind.svg" },
      { label: "JIRA", level: 4, logo: "/logos/jira.svg" },
      { label: "Sketch", level: 3, logo: "/logos/sketch.svg" },
      { label: "Visio", level: 3, logo: "/logos/visio.svg" },
    ],
  },
];
---

<BaseLayout sideBarActiveItemID="skills">
  <div class="pb-12 mt-5">
    <div class="text-3xl font-bold mb-2">技能与工具</div>
    <p class="text-base-content/50 text-sm mb-8">进度条越长 = 越擅长</p>
    <SkillBoard categories={categories} />
  </div>
</BaseLayout>
