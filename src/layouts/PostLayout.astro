---
import { type BlogSchema } from "../content/config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

interface PostNav {
  title: string;
  url: string;
}

export interface Props extends BlogSchema {
  prevPost?: PostNav;
  nextPost?: PostNav;
}

const { title, description, pubDate, updatedDate, heroImage, badge, tags = [], prevPost, nextPost } = Astro.props;
dayjs.extend(localizedFormat);

const postBadgeColors: Record<string, string> = {
  "商业化": "oklch(0.48 0.10 260)",
  "增长": "oklch(0.48 0.10 180)",
  "出海": "oklch(0.52 0.10 50)",
  "工作流": "oklch(0.50 0.10 30)",
  "AI 转型": "oklch(0.48 0.08 280)",
};
const postBadgeColor = badge ? (postBadgeColors[badge] || "oklch(0.65 0.10 180)") : "";
const displayDate = dayjs(pubDate).format("ll");
import { Image } from "astro:assets";

const tag_url = "/blog/tag";
---

<BaseLayout title={title} description={description} image={heroImage} ogType="article" enablePageScroll={false}>
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto post-article">
      {heroImage && <Image width={750} height={422} format="webp" src={heroImage} alt={title} class="w-full mb-6 rounded-xl" />}

      <!-- Article header -->
      <div class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time class="post-meta__date">{displayDate}</time>
          {badge && <span class="post-meta__badge" style={`background: ${postBadgeColor};`}>{badge}</span>}
        </div>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a href={`${tag_url}/${tag}`} class="post-tag">#{tag}</a>
            ))}
          </div>
        )}
      </div>

      <!-- TL;DR -->
      <div class="post-tldr">
        <span class="post-tldr__label">导读</span>
        <p class="post-tldr__text">{description}</p>
      </div>

      <!-- TOC - auto generated from h2 -->
      <nav class="post-toc" id="post-toc">
        <div class="post-toc__header">
          <span class="post-toc__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
          </span>
          <span class="post-toc__title">目录</span>
        </div>
        <ol class="post-toc__list" id="post-toc-list">
          <!-- JS will populate -->
        </ol>
      </nav>

      {updatedDate && (
        <p class="post-updated">最后更新于 <time>{dayjs(updatedDate).format("ll")}</time></p>
      )}

      <!-- Article body -->
      <div class="post-body" id="post-body">
        <slot />
      </div>

      <!-- Prev / Next navigation -->
      {(prevPost || nextPost) && (
        <nav class="post-nav">
          {prevPost ? (
            <a href={prevPost.url} class="post-nav__item post-nav__item--prev">
              <span class="post-nav__label">← 上一篇</span>
              <span class="post-nav__title">{prevPost.title}</span>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={nextPost.url} class="post-nav__item post-nav__item--next">
              <span class="post-nav__label">下一篇 →</span>
              <span class="post-nav__title">{nextPost.title}</span>
            </a>
          ) : <div />}
        </nav>
      )}

      <!-- Back to blog -->
      <div class="post-back">
        <a href="/blog" class="post-back__link">← 返回所有文章</a>
      </div>
    </article>
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', async () => {
    // Mermaid rendering
    const mermaidDivs = document.querySelectorAll('.mermaid');
    if (mermaidDivs.length > 0) {
      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
      mermaid.initialize({
        startOnLoad: false,
        theme: 'base',
        themeVariables: {
          primaryColor: '#e0f2f1',
          primaryBorderColor: '#4db6ac',
          primaryTextColor: '#2d3748',
          lineColor: '#4db6ac',
          secondaryColor: '#f0fdf4',
          tertiaryColor: '#f5f5f5',
          fontSize: '14px',
        },
        flowchart: { curve: 'basis', padding: 16 },
      });
      await mermaid.run({ nodes: mermaidDivs });
      // Wrap rendered diagrams in styled containers
      mermaidDivs.forEach((div) => {
        div.classList.add('mermaid-diagram');
      });
    }

    const body = document.getElementById('post-body');
    const tocList = document.getElementById('post-toc-list');
    const toc = document.getElementById('post-toc');
    if (!body || !tocList || !toc) return;

    const headings = body.querySelectorAll('h2');
    if (headings.length === 0) {
      toc.style.display = 'none';
      return;
    }

    // Build TOC
    headings.forEach((h, i) => {
      const id = 'section-' + i;
      h.setAttribute('id', id);

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = h.textContent || '';
      a.className = 'post-toc__link';
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Highlight active TOC item on scroll
    const links = tocList.querySelectorAll('.post-toc__link');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          links.forEach((link) => {
            if (link.getAttribute('href') === '#' + id) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    }, { rootMargin: '-20% 0px -60% 0px' });

    headings.forEach((h) => observer.observe(h));
  });
</script>

<style is:global>
  /* Post header */
  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 1.85rem !important;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 0.75rem !important;
    margin-top: 0 !important;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
  }

  .post-meta__date {
    font-size: 0.78rem;
    color: oklch(0.55 0.03 195);
  }

  .post-meta__badge {
    font-size: 0.65rem;
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    background: oklch(0.65 0.10 180);
    color: #fff;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.7rem !important;
    color: oklch(0.55 0.06 180) !important;
    background: oklch(0.95 0.02 185 / 0.5);
    padding: 0.15rem 0.5rem;
    border-radius: 1rem;
    text-decoration: none !important;
    transition: background 0.2s ease;
  }

  .post-tag:hover {
    background: oklch(0.90 0.04 180 / 0.6);
  }

  /* TL;DR block */
  .post-tldr {
    background: linear-gradient(135deg, oklch(0.97 0.015 190 / 0.6), oklch(0.96 0.012 195 / 0.4));
    border-left: 3px solid oklch(0.68 0.10 180);
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1rem 1.25rem;
    margin-bottom: 1.25rem !important;
    margin-top: 0 !important;
  }

  .post-tldr__label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: oklch(0.52 0.08 180);
    margin-bottom: 0.3rem;
  }

  .post-tldr__text {
    font-size: 0.88rem !important;
    color: oklch(0.38 0.03 200);
    line-height: 1.65 !important;
    margin: 0 !important;
  }

  /* TOC */
  .post-toc {
    background: oklch(0.98 0.008 195 / 0.5);
    border: 1px solid oklch(0.93 0.015 190 / 0.5);
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem !important;
    margin-top: 0 !important;
  }

  .post-toc__header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
  }

  .post-toc__icon {
    color: oklch(0.55 0.07 180);
    display: flex;
  }

  .post-toc__title {
    font-size: 0.72rem;
    font-weight: 600;
    color: oklch(0.50 0.05 185);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-toc__list {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    counter-reset: toc;
  }

  .post-toc__list li {
    padding: 0 !important;
    margin: 0 !important;
  }

  .post-toc__link {
    display: block;
    font-size: 0.8rem !important;
    color: oklch(0.48 0.03 200) !important;
    text-decoration: none !important;
    padding: 0.3rem 0.6rem;
    border-radius: 0.4rem;
    border-left: 2px solid transparent;
    transition: all 0.25s ease;
    counter-increment: toc;
  }

  .post-toc__link::before {
    content: counter(toc) ". ";
    color: oklch(0.62 0.06 180);
    font-weight: 500;
  }

  .post-toc__link:hover {
    background: oklch(0.95 0.02 185 / 0.5);
    color: oklch(0.38 0.05 185) !important;
  }

  .post-toc__link.active {
    border-left-color: oklch(0.62 0.10 180);
    background: oklch(0.95 0.02 185 / 0.5);
    color: oklch(0.38 0.08 180) !important;
    font-weight: 500;
  }

  .post-updated {
    font-size: 0.72rem !important;
    color: oklch(0.55 0.03 195);
    margin-bottom: 1rem !important;
  }

  /* Article body typography */
  .post-body h2 {
    font-size: 1.3rem !important;
    font-weight: 700;
    margin-top: 2.5rem !important;
    margin-bottom: 1rem !important;
    padding-bottom: 0.4rem;
    border-bottom: 1.5px solid oklch(0.93 0.02 190 / 0.5);
    color: oklch(0.28 0.03 200);
    scroll-margin-top: 2rem;
  }

  .post-body h3 {
    font-size: 1.1rem !important;
    font-weight: 600;
    color: oklch(0.35 0.04 195);
    margin-top: 1.8rem !important;
  }

  .post-body p {
    font-size: 0.92rem !important;
    line-height: 1.85 !important;
    color: oklch(0.38 0.02 210);
    margin-bottom: 1.1rem !important;
  }

  .post-body strong {
    color: oklch(0.45 0.08 180);
    font-weight: 600;
  }

  .post-body ul, .post-body ol {
    margin-left: 0.5rem !important;
    margin-bottom: 1.2rem !important;
  }

  .post-body li {
    font-size: 0.9rem !important;
    line-height: 1.8 !important;
    color: oklch(0.40 0.02 210);
    margin-bottom: 0.35rem !important;
  }

  .post-body li::marker {
    color: oklch(0.65 0.08 180);
  }

  .post-body blockquote {
    border-left-color: oklch(0.72 0.08 180) !important;
    background: oklch(0.97 0.01 195 / 0.4);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.75rem 1rem !important;
    font-style: normal !important;
  }

  .post-body blockquote p {
    color: oklch(0.42 0.03 200) !important;
    font-size: 0.88rem !important;
  }

  .post-body :not(pre) > code {
    background: oklch(0.95 0.015 190 / 0.5) !important;
    color: oklch(0.45 0.06 180) !important;
    padding: 0.15rem 0.4rem !important;
    border-radius: 0.3rem !important;
    font-size: 0.82rem !important;
  }

  .post-body a {
    color: oklch(0.50 0.10 180) !important;
    text-decoration-color: oklch(0.70 0.06 180 / 0.4) !important;
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  .post-body a:hover {
    color: oklch(0.42 0.12 175) !important;
    text-decoration-color: oklch(0.50 0.10 180) !important;
  }

  .post-body hr {
    border: none !important;
    border-top: 1.5px solid oklch(0.93 0.02 190 / 0.5) !important;
    margin: 2rem 0 !important;
  }

  /* Reference section */
  .post-body h2:last-of-type {
    font-size: 1rem !important;
    color: oklch(0.50 0.03 195);
    border-bottom: none;
  }

  .post-body h2:last-of-type ~ p {
    font-size: 0.78rem !important;
    color: oklch(0.55 0.02 200);
    line-height: 1.6 !important;
    margin-bottom: 0.4rem !important;
  }

  .post-body h2:last-of-type ~ p a {
    font-size: 0.78rem !important;
    color: oklch(0.55 0.05 190) !important;
  }

  /* Prev / Next navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 3rem !important;
    margin-bottom: 1.5rem !important;
  }

  .post-nav__item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.15rem;
    border: 1px solid oklch(0.93 0.015 195 / 0.5);
    border-radius: 0.75rem;
    text-decoration: none !important;
    transition: all 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .post-nav__item:hover {
    background: oklch(0.97 0.012 190 / 0.6);
    border-color: oklch(0.85 0.04 185 / 0.5);
    box-shadow: 0 4px 16px oklch(0.80 0.05 190 / 0.12);
  }

  .post-nav__item--next {
    text-align: right;
  }

  .post-nav__label {
    font-size: 0.65rem;
    color: oklch(0.58 0.06 180);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .post-nav__title {
    font-size: 0.85rem !important;
    color: oklch(0.35 0.03 200) !important;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Back link */
  .post-back {
    text-align: center;
    margin-top: 1rem !important;
    margin-bottom: 2rem !important;
  }

  .post-back__link {
    font-size: 0.78rem !important;
    color: oklch(0.55 0.05 190) !important;
    text-decoration: none !important;
    transition: color 0.2s ease;
  }

  .post-back__link:hover {
    color: oklch(0.45 0.08 180) !important;
  }

  /* Mermaid diagrams */
  .mermaid-diagram {
    display: flex;
    justify-content: center;
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: oklch(0.98 0.008 195 / 0.5);
    border: 1px solid oklch(0.93 0.015 190 / 0.5);
    border-radius: 0.75rem;
    overflow-x: auto;
  }

  .mermaid-diagram svg {
    max-width: 100%;
    height: auto;
  }

  /* SVG design figures */
  .design-figure {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, oklch(0.98 0.01 190 / 0.6), oklch(0.97 0.008 200 / 0.4));
    border: 1px solid oklch(0.92 0.02 185 / 0.5);
    border-radius: 0.75rem;
  }

  .design-figure__title {
    font-size: 0.72rem;
    font-weight: 600;
    color: oklch(0.50 0.06 180);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    text-align: center;
  }

  .design-figure svg {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    height: auto;
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .design-figure {
      padding: 1rem;
    }
  }
</style>
